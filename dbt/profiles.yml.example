nz_electricity:
  target: dev
  outputs:
    # ── Local development: DuckDB (no cloud creds needed) ────────────
    dev:
      type: duckdb
      path: "{{ env_var('NZEG_DUCKDB_PATH', '../data/nzeg.duckdb') }}"
      threads: 4
      # Models materialize under raw/staging/analytics schemas inside the
      # single .duckdb file. The file is gitignored under data/.

    # ── Cloud production: Snowflake (key-pair auth) ──────────────────
    prod:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE') }}"
      database: "{{ env_var('SNOWFLAKE_DATABASE') }}"
      schema: RAW
      threads: 4

    # ── CI placeholder: parses without real creds ────────────────────
    ci:
      type: snowflake
      account: dummy
      user: dummy
      password: dummy
      role: dummy
      warehouse: dummy
      database: dummy
      schema: RAW
      threads: 1
